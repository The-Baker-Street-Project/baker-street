# Example: bakerst-brain-secrets
# Use scripts/deploy-all.sh or the Rust installer instead of manual apply.
apiVersion: v1
kind: Secret
metadata:
  name: bakerst-brain-secrets
  namespace: bakerst
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "sk-ant-api03-your-key-here"
  DEFAULT_MODEL: "claude-sonnet-4-20250514"
  OPENAI_API_KEY: ""
  OLLAMA_ENDPOINTS: ""
  VOYAGE_API_KEY: ""
  AUTH_TOKEN: ""
  AGENT_NAME: "Baker"
---
